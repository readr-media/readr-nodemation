# Worker Configuration
LOG_LEVEL=info

# Database Configuration
# Local dev (docker-compose.dev.yml):
#   DATABASE_URL="postgresql://ndx:ndx@localhost:5433/workflow?schema=public"
# Cloud SQL (production, unix socket — injected via Secret Manager):
DATABASE_URL="postgresql://USER:PASSWORD@localhost/workflow?host=/cloudsql/mirrorlearning-161006:asia-east1:INSTANCE_NAME&schema=public"

# Polling interval in seconds
# Set to 0 for single-run mode (recommended for Cloud Scheduler)
# Set to > 0 for continuous polling mode (for local development)
POLL_INTERVAL=0

# Storage Configuration (for file exports)
STORAGE_PATH=/tmp/workflow-storage

# Execution Configuration
MAX_CONCURRENCY=10
ERROR_STRATEGY=retry
MAX_RETRIES=3
RETRY_DELAY=5

# Vertex AI Configuration (for aiCall node)
GOOGLE_CLOUD_PROJECT=your-project-id
VERTEX_AI_PROJECT=your-project-id
VERTEX_AI_LOCATION=us-central1

# READr CMS Configuration (for cmsInput/cmsOutput nodes)
READR_CMS_API_KEY=your-cms-api-key
READR_CMS_ENDPOINT=https://cms.example.com

# Docker Configuration (for codeBlock node)
DOCKER_IMAGE=node:20-alpine
DOCKER_TIMEOUT=300
